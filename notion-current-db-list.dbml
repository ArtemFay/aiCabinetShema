Table "🏛️ ОРГАНИЗАЦИИ" as notion_organizations {
  notion_id text [pk]
  "ОРГАНИЗАЦИЯ" text [not null, note: "Notion type: title"]
  "Created" timestamp [note: "Notion type: created_time"]
  "Last edited" timestamp [note: "Notion type: last_edited_time"]
  "ВЕКТОР ДЕЯТЕЛЬНОСТИ" text [note: "Notion type: text"]
  "ВЕС ДОВЕРИЯ" numeric [note: "Notion type: number"]
  "ГРУППЫ" text [note: "Notion type: relation"]
  "ДАТА ПРОВЕРКИ" date [note: "Notion type: date"]
  "ИЗМЕНЕНО КЕМ" text [note: "Notion type: select"]
  "ИСТОЧНИКИ" text [note: "Notion type: relation"]
  "ЛЮДИ" text [note: "Notion type: relation"]
  "ОПИСАНИЕ" text [note: "Notion type: text"]
  "ПРИЧИНА ИЗМЕНЕНИЯ AI" text [note: "Notion type: text"]
  "ПРОВЕРЕНО КЕМ" text [note: "Notion type: person"]
  "ПРОЕКТЫ" text [note: "Notion type: relation"]
  "СОБЫТИЯ" text [note: "Notion type: relation"]
  "СОЗДАНО КЕМ" text [note: "Notion type: select"]
  "СТАТУС" text [note: "Notion type: status"]
  "СТАТУС ВАЛИДАЦИИ" text [note: "Notion type: select"]
  "ТЕМЫ" text [note: "Notion type: relation"]
  "ТИП ОРГАНИЗАЦИИ" text [note: "Notion type: select"]
}

Table "🍥 ДНИ_DB" as notion_days {
  notion_id text [pk]
  "ДНИ" text [not null, note: "Notion type: title"]
  "3 дня" text [note: "Notion type: formula"]
  "3 цели дня" text [note: "Notion type: text"]
  "Related to СОБЫТИЯ/ПРОЕКТЫ (1) (🍥 ДНИ_DB)" text [note: "Notion type: relation"]
  "Rollup" text [note: "Notion type: rollup"]
  "Week" text [note: "Notion type: formula"]
  "ID" int [note: "Notion type: auto_increment_id"]
  "ВЕС ДОВЕРИЯ" numeric [note: "Notion type: number"]
  "Вес" numeric [note: "Notion type: number"]
  "ГОДЫ_DB" text [note: "Notion type: relation"]
  "Год" text [note: "Notion type: formula"]
  "Город" text [note: "Notion type: multi_select"]
  "ДАТА ПРОВЕРКИ" date [note: "Notion type: date"]
  "ДОСТИЖЕНИЯ" text [note: "Notion type: relation"]
  "Дата ДЕНЬ БД" date [note: "Notion type: date"]
  "Заголовок ДЕНЬ" text [note: "Notion type: text"]
  "Заголовок УТРО" text [note: "Notion type: text"]
  "ИЗМЕНЕНО КЕМ" text [note: "Notion type: select"]
  "КВАРТАЛЫ_DB" text [note: "Notion type: relation"]
  "КОНТЕНТ" text [note: "Notion type: relation"]
  "Календарь" text [note: "Notion type: formula"]
  "Коммент по контенту" text [note: "Notion type: rollup"]
  "Лайфстайл" text [note: "Notion type: multi_select"]

  Note: "Схема частичная: полный fetch был обрезан."
}

Table "ЛЮДИ" as notion_people { notion_id text [pk] }
Table "ГРУППЫ" as notion_groups { notion_id text [pk] }
Table "РОЛИ В ОРГАНИЗАЦИЯХ" as notion_org_roles { notion_id text [pk] }
Table "ГОДЫ_DB" as notion_years { notion_id text [pk] }
Table "КВАРТАЛЫ_DB" as notion_quarters { notion_id text [pk] }
Table "МЕСЯЦЫ_DB" as notion_months { notion_id text [pk] }
Table "НЕДЕЛИ_DB" as notion_weeks { notion_id text [pk] }
Table "Tasks" as notion_tasks { notion_id text [pk] }
Table "Projects" as notion_projects { notion_id text [pk] }
Table "СОБЫТИЯ" as notion_events { notion_id text [pk] }

// =========================
// Связи, подтверждённые relation-полями
// =========================

Ref: notion_sources."ТЕМЫ" > notion_topics.notion_id
Ref: notion_sources."ЛЮДИ" > notion_people.notion_id
Ref: notion_sources."ДНИ" > notion_days.notion_id
Ref: notion_sources."ЦИТАТЫ" > notion_id_refs.notion_id

Ref: notion_claims."ИСТОЧНИКИ" > notion_sources.notion_id
Ref: notion_claims."ТЕМЫ" > notion_topics.notion_id
Ref: notion_claims."ЛЮДИ" > notion_people.notion_id
Ref: notion_claims."ДНИ" > notion_days.notion_id
Ref: notion_claims."ГРУППЫ" > notion_groups.notion_id
Ref: notion_claims."ОРГАНИЗАЦИИ" > notion_organizations.notion_id
Ref: notion_claims."ПРОЕКТЫ" > notion_projects.notion_id
Ref: notion_claims."СОБЫТИЯ" > notion_events.notion_id
Ref: notion_claims."ОСНОВАНИЯ" > notion_claims.notion_id
Ref: notion_claims."ОБОСНОВЫВАЕТ" > notion_claims.notion_id

Ref: notion_topics."Parent item" > notion_topics.notion_id
Ref: notion_topics."Sub-item" > notion_topics.notion_id

Ref: notion_organizations."ИСТОЧНИКИ" > notion_sources.notion_id
Ref: notion_organizations."СОБЫТИЯ" > notion_events.notion_id
Ref: notion_organizations."ПРОЕКТЫ" > notion_projects.notion_id
Ref: notion_organizations."ТЕМЫ" > notion_topics.notion_id
Ref: notion_organizations."ЛЮДИ" > notion_people.notion_id
Ref: notion_organizations."ГРУППЫ" > notion_groups.notion_id

Ref: notion_days."ГОДЫ_DB" > notion_years.notion_id
Ref: notion_days."КВАРТАЛЫ_DB" > notion_quarters.notion_id
Ref: notion_days."КОНТЕНТ" > notion_sources.notion_id

Table "НЕРАЗОБРАННЫЕ ССЫЛКИ" as notion_id_refs {
  notion_id text [pk]
}
