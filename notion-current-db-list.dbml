Project notion_current_as_is {
  database_type: "PostgreSQL"
  Note: "Текущий снимок структуры Notion as-is. Названия баз и полей сохранены как в оригинале. Типы указаны по схеме Notion."
}

// =========================
// СМЫСЛЫ — полностью проработано
// =========================

Table "🎞️ ИСТОЧНИКИ" as notion_sources {
  notion_id text [pk, note: "collection://2fbbd3ce-ad74-483b-9022-c867ec04d388"]
  "НАЗВАНИЕ" text [not null, note: "Notion type: title"]
  "Created" timestamp [note: "Notion type: created_time"]
  "Files & media" text [note: "Notion type: file"]
  "IMDB" numeric [note: "Notion type: number"]
  "SUMMARY" text [note: "Notion type: text"]
